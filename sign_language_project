

import cv2
from ultralytics import YOLO
import supervision as sv
import yaml
import time
import os


local_model_path = 'C:\\Users\\ilike\\Documents\\10 Spring Semester 2026\\Digital Image Processing\\Final Project\\best.pt'

model = YOLO(local_model_path)

local_data_yaml_path = 'C:\\Users\\ilike\\Documents\\10 Spring Semester 2026\\Digital Image Processing\\Final Project\\data.yaml'

class_names = []
try:
    with open(local_data_yaml_path, 'r') as f:
        data = yaml.safe_load(f)
    class_names = data['names']
    print(f"Loaded class names: {class_names}")
except FileNotFoundError:
    print(f"Warning: {local_data_yaml_path} not found. Class names will be generic.")

box_annotator = sv.BoxAnnotator(thickness=2)
label_annotator = sv.LabelAnnotator(text_color=sv.Color.BLACK, text_scale=0.8)

# Open the default webcam
cap = cv2.VideoCapture(0)

if not cap.isOpened():
    print("Error: Could not open webcam. Make sure it's connected and not in use.")
else:
    print("Webcam opened successfully. Press 'q' to quit the live feed.")
    try:
        last_detection_time = 0
        interval = 1

        last_detections = None
        last_labels = []
        while True:
            ret, frame = cap.read()
            if not ret:
                print("Error: Could not read frame from webcam.")
                break
            current_time = time.time()

            if current_time - last_detection_time>= interval:
                results = model(frame, conf=0.25, iou=0.7, verbose=False)[0]
                detections = sv.Detections.from_ultralytics(results)

            # Prepare labels for annotation
                if class_names:
                    labels = [
                        f"{class_names[int(class_id)]} {confidence:.2f}"
                        for class_id, confidence
                        in zip(detections.class_id, detections.confidence)
                    ]
                else:
                    labels = [
                        f"Class {int(class_id)} {confidence:.2f}"
                        for class_id, confidence
                        in zip(detections.class_id, detections.confidence)
                    ]
                if labels:
                    for label in labels:
                        print(f" - {label}")
                else:
                    print("\n")

                last_detections = detections
                last_labels = labels
                last_detection_time = current_time

            annotated_frame = frame.copy()
            
            if last_detections is not None:
            # Annotate the frame
                annotated_frame = box_annotator.annotate(scene=frame.copy(), detections=detections)
                annotated_frame = label_annotator.annotate(scene=annotated_frame, detections=last_detections, labels=last_labels)

            # Display the annotated frame
            cv2.imshow('YOLO11 Live Detection (Ultralytics .pt)', annotated_frame)

            # Break the loop on 'q' key press
            if cv2.waitKey(1) & 0xFF == ord('q'):
                print("Exiting webcam feed.")
                break
    finally:
        # Release the webcam and destroy all OpenCV windows
        cap.release()
        cv2.destroyAllWindows()

print("Webcam closed")
